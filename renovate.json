{
  "extends": [
    "config:base",
    "docker:disable",
    ":disableDependencyDashboard",
    "config:recommended"
  ],
  "constraintsFiltering": "strict",
  "pinVersions": false,
  "rebaseStalePrs": true,
  "rangeStrategy": "bump",
  "labels": ["dependencies"],
  "automerge": false,
  "schedule": ["at any time"],
  "gitAuthor": null,
  "packageRules": [
    {
      "extends": "packages:linters",
      "groupName": "linters"
    },
    {
      "matchManagers": ["github-actions"],
      "enabled": false
      }],   
  "ignoreDeps": ["typescript"]
}